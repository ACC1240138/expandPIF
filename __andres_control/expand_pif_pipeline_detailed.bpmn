<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_expand_pif_pipeline" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn:collaboration id="Collaboration_expand_pif">
    <bpmn:participant id="Participant_expand_pif" name="expand_pif.ipynb - flujo documental y computacional" processRef="Process_expand_pif" />
    <bpmn:textAnnotation id="Annotation_enpg">
      <bpmn:text>Deriva consumo g/dia calibrado, cvolaj/cvolajms, abstemio, ex-bebedor fd, HED/binge, sexo y edad_tramo 1-4. Escribe cache de sensibilidad binge.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_scope">
      <bpmn:text>Notebook Quarto/Jupyter con execute-dir: project. Limpia la sesion, carga paquetes y produce salida HTML. El motor contiene PIF, pero en este flujo observado el cuaderno usa principalmente la ruta AAF para mortalidad atribuible.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_design">
      <bpmn:text>revision_diseno_enpg_extension.R cruza ENPG_BINGE con lookup minimo 2022/2024, calcula neff Kish, factores PSU por abs/form/hed/consumo y entrega kish para aaf_unified.R.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_registry">
      <bpmn:text>load_adam_rr_registry(scope): cancer/hhd/general usan GENERAL_chronic_RR_2024_08_23.R; ihd usa GENERAL_ihd_RR_2018_03_16.R; is usa GENERAL_IS_RR_2018_03_16.R; injuries usa GENERAL_injuries_RR_2018_03_16.R. Valida campos RRCurrent, beta, covarianzas, former drinker y binge cuando aplica.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_compute">
      <bpmn:text>aaf_unified.R integra RR sobre distribuciones gamma. No-HED: cancer, HHD, general.
HED cap: IHD e ischaemic stroke con RR&gt;=1 en binge.
HED explicito: injuries con beta binge.
Monte Carlo usa n_sim, n_pca, seed, neff, design_factor y fd_uncertainty.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_validation">
      <bpmn:text>Validaciones: preflight de listas gamma/prevalencias/grillas;
registry metadata;
AAF finita, CI ordenado y AAF&lt;=1;
aaf_error_log;
chequeo de llaves antes de unir con mortalidad.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_outputs">
      <bpmn:text>Productos principales:
 - data_binge_sensitivity.rds,
 - mortality_dataV2.rds,
 - aaf_engine_inputs_bundle,
 - aaf_nested_by_disease,
 - tabla AAF WHO 2024,
 - Mortality Estimates WHO 2024.xlsx,
 - figuras PNG,
 - tablas de burden/rates,
 - comparaciones JRT</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_enpg_note" sourceRef="Task_enpg" targetRef="Annotation_enpg" />
    <bpmn:association id="Assoc_compute_note" sourceRef="Task_compute_aaf" targetRef="Annotation_compute" />
    <bpmn:association id="Assoc_registry_note" sourceRef="Task_load_registry" targetRef="Annotation_registry" />
    <bpmn:association id="Assoc_validation_note" sourceRef="Task_save_aaf" targetRef="Annotation_validation" />
    <bpmn:association id="Assoc_outputs_note" sourceRef="Task_figures_tables" targetRef="Annotation_outputs" />
    <bpmn:association id="Assoc_scope" sourceRef="Task_setup" targetRef="Annotation_scope" />
    <bpmn:association id="Assoc_design_note" sourceRef="Task_design" targetRef="Annotation_design" />
  </bpmn:collaboration>
  <bpmn:process id="Process_expand_pif" isExecutable="false">
    <bpmn:laneSet id="LaneSet_expand_pif">
      <bpmn:lane id="Lane_outputs" name="Productos, validaciones y comparaciones">
        <bpmn:flowNodeRef>Task_wide_aaf</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_export_aaf_table</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_join_mortality</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_jrt_compare</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_figures_tables</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_rr_engine" name="RR Adam/WHO y motor AAF/PIF">
        <bpmn:flowNodeRef>Task_source_engine</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_load_registry</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_compute_aaf</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_save_aaf</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_mortality" name="Mortalidad, causas y poblacion">
        <bpmn:flowNodeRef>Task_mortality</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_icd_flags</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_population</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_exposure" name="Exposicion ENPG y diseno">
        <bpmn:flowNodeRef>Task_aaf_inputs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_enpg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_design</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_orchestration" name="Orquestacion notebook">
        <bpmn:flowNodeRef>Start_expand_pif</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_setup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_session_html</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_artifacts</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_expand_pif" name="Abrir / ejecutar notebook">
      <bpmn:outgoing>Flow_start_setup</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_setup" name="Setup R y paquetes">
      <bpmn:incoming>Flow_start_setup</bpmn:incoming>
      <bpmn:outgoing>Flow_setup_enpg</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_mortality" name="Importar y consolidar DEIS 2012-2024">
      <bpmn:incoming>Flow_design_mortality</bpmn:incoming>
      <bpmn:outgoing>Flow_mortality_icd</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_icd_flags" name="Etiquetar causas ICD-10 y AAF=1">
      <bpmn:incoming>Flow_mortality_icd</bpmn:incoming>
      <bpmn:outgoing>Flow_icd_inputs</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_aaf_inputs" name="Construir inputs AAF y auditoria previa">
      <bpmn:incoming>Flow_icd_inputs</bpmn:incoming>
      <bpmn:outgoing>Flow_inputs_source</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_wide_aaf" name="Armar AAF wide por sexo">
      <bpmn:incoming>Flow_save_wide</bpmn:incoming>
      <bpmn:outgoing>Flow_wide_export_table</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_export_aaf_table" name="Exportar tabla AAF WHO 2024">
      <bpmn:incoming>Flow_wide_export_table</bpmn:incoming>
      <bpmn:outgoing>Flow_export_join</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_join_mortality" name="Unir AAF con muertes y exportar Excel">
      <bpmn:incoming>Flow_export_join</bpmn:incoming>
      <bpmn:outgoing>Flow_join_population</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_jrt_compare" name="Comparar cancer con JRT">
      <bpmn:incoming>Flow_population_jrt</bpmn:incoming>
      <bpmn:outgoing>Flow_jrt_figures</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_figures_tables" name="Generar figuras, tablas y resultados">
      <bpmn:incoming>Flow_jrt_figures</bpmn:incoming>
      <bpmn:outgoing>Flow_figures_session</bpmn:outgoing>
    </bpmn:task>
    <bpmn:dataObjectReference id="DataRef_data_binge" name="PIF addiction/data_binge_sensitivity.rds" dataObjectRef="DataObject_data_binge" />
